# ─── DATABASE ───────────────────────────────────────────────
# Local dev uses Docker Postgres; production uses Supabase.
# In production use the Supabase connection POOLER URL (port 6543), not the
# direct connection (port 5432), so serverless functions don't exhaust
# Postgres connections, e.g.:
#   postgresql://...@...supabase.com:6543/postgres?pgbouncer=true&connection_limit=1
DATABASE_URL=""

# ─── NEXTAUTH ───────────────────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET=""   # generate with: openssl rand -base64 32

# ─── CIRCLE ─────────────────────────────────────────────────
# Get from: https://console.circle.com
CIRCLE_API_KEY=""
CIRCLE_ENTITY_SECRET=""
CIRCLE_WALLET_SET_ID=""
CIRCLE_ENVIRONMENT="sandbox"
# Platform fee wallet (receives protocol fees at settlement).
# Create with: npm run circle:platform-wallet
PLATFORM_WALLET_ID=""
PLATFORM_WALLET_ADDRESS=""

# ─── ARC TESTNET ────────────────────────────────────────────
ARC_RPC_URL="https://rpc.testnet.arc.network"
ARC_CHAIN_ID="5042002"

# ─── ANTHROPIC ──────────────────────────────────────────────
ANTHROPIC_API_KEY=""

# ─── EMAIL (buyer verification) ─────────────────────────────
# Prefer Resend (set RESEND_API_KEY); otherwise SMTP (e.g. Gmail app password).
# With neither set, the magic link is logged to the server console.
EMAIL_FROM="Meridian <onboarding@resend.dev>"
RESEND_API_KEY=""
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="465"
SMTP_USER=""
SMTP_PASS=""

# ─── APP CONFIG ─────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="Meridian"
NEXT_PUBLIC_CIRCLE_ENVIRONMENT="sandbox"
# Demo Autopilot (/demo) and its public, DB-writing endpoints (/api/demo/*) are
# OFF unless this is exactly "demo". KEEP THIS UNSET IN PRODUCTION — when on,
# anyone can trigger demo runs that seed users/wallets/invoices.
NEXT_PUBLIC_APP_ENV=""
# Password for the seeded demo accounts (sme@ / investor@meridian.test). Only
# needed if you want to log in as them to show the dashboard; if unset, a strong
# random password is used and the accounts can't be signed into. Use a strong value.
DEMO_ACCOUNT_PASSWORD=""

# ─── CIRCLE WEBHOOK ─────────────────────────────────────────
CIRCLE_WEBHOOK_SECRET=""

# ─── USYC YIELD (idle-capital) ──────────────────────────────
# "simulated" (default) models USYC yield on Arc as a ledger earmark — safe for
# demos. "real" runs actual subscribe/redeem on the USYC Teller on Ethereum
# Sepolia (USYC isn't deployed on Arc).
USYC_MODE="simulated"
# Annual yield rate used for simulated accrual (percent).
USYC_APY="4.5"
# Required only when USYC_MODE="real": a Circle wallet on Ethereum Sepolia,
# funded with test USDC + Sepolia ETH (for gas). Create via the Circle console
# or setup script, then paste its wallet id here.
USYC_SEPOLIA_WALLET_ID=""

# ─── RATE LIMITING (Upstash Redis) ──────────────────────────
# Free tier at upstash.com. When unset, rate limiting is disabled (requests are
# allowed) — the app still works, it just isn't throttled.
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ─── ERROR TRACKING (Sentry) ────────────────────────────────
# Free tier at sentry.io. When unset, error tracking is inert (no network calls).
SENTRY_DSN=""
