# ─── DATABASE ───────────────────────────────────────────────
# Local dev uses Docker Postgres; production uses Supabase.
DATABASE_URL=""

# ─── NEXTAUTH ───────────────────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET=""   # generate with: openssl rand -base64 32

# ─── CIRCLE ─────────────────────────────────────────────────
# Get from: https://console.circle.com
CIRCLE_API_KEY=""
CIRCLE_ENTITY_SECRET=""
CIRCLE_WALLET_SET_ID=""
CIRCLE_ENVIRONMENT="sandbox"
# Platform fee wallet (receives protocol fees at settlement).
# Create with: npm run circle:platform-wallet
PLATFORM_WALLET_ID=""
PLATFORM_WALLET_ADDRESS=""

# ─── ARC TESTNET ────────────────────────────────────────────
ARC_RPC_URL="https://rpc.testnet.arc.network"
ARC_CHAIN_ID="5042002"

# ─── ANTHROPIC ──────────────────────────────────────────────
ANTHROPIC_API_KEY=""

# ─── EMAIL (buyer verification) ─────────────────────────────
# Prefer Resend (set RESEND_API_KEY); otherwise SMTP (e.g. Gmail app password).
# With neither set, the magic link is logged to the server console.
EMAIL_FROM="Meridian <onboarding@resend.dev>"
RESEND_API_KEY=""
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="465"
SMTP_USER=""
SMTP_PASS=""

# ─── APP CONFIG ─────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="Meridian"
NEXT_PUBLIC_CIRCLE_ENVIRONMENT="sandbox"
# Set to "demo" to enable the one-click Demo Autopilot (/demo). Leave unset in prod.
NEXT_PUBLIC_APP_ENV="demo"

# ─── CIRCLE WEBHOOK ─────────────────────────────────────────
CIRCLE_WEBHOOK_SECRET=""
