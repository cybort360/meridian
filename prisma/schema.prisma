generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String
  passwordHash  String
  role          UserRole  @default(SME)
  companyName   String?
  country       String    @default("UAE")
  hasSeenOnboarding Boolean @default(false)
  kycStatus     KycStatus @default(NOT_SUBMITTED)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  wallet        Wallet?
  invoices      Invoice[] @relation("SMEInvoices")
  funded        Invoice[] @relation("InvestorInvoices")
  sessions      Session[]
  kycSubmission KycSubmission?
  yieldPositions YieldPosition[]
}

enum UserRole {
  SME
  INVESTOR
  ADMIN
}

enum KycStatus {
  NOT_SUBMITTED
  PENDING_REVIEW
  APPROVED
  REJECTED
}

model KycSubmission {
  id                    String    @id @default(cuid())
  userId                String    @unique

  // Business details
  legalBusinessName     String
  tradeLicenseNumber    String
  commercialRegNumber   String
  businessAddress       String
  city                  String
  country               String    @default("UAE")
  industry              String
  websiteUrl            String?
  phoneNumber           String

  // Document paths (stored as file paths or URLs)
  tradeLicenseDocUrl    String
  ownerIdDocUrl         String
  proofOfAddressUrl     String?

  // Review
  reviewedAt            DateTime?
  reviewNotes           String?
  submittedAt           DateTime  @default(now())

  user                  User      @relation(fields: [userId], references: [id])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Wallet {
  id              String          @id @default(cuid())
  userId          String?         @unique   // null for per-invoice escrow wallets
  circleWalletId  String          @unique
  address         String          @unique
  blockchain      String          @default("ARC")
  isEscrow        Boolean         @default(false)
  invoiceId       String?                   // set when this is an invoice's escrow wallet
  createdAt       DateTime        @default(now())

  user            User?           @relation(fields: [userId], references: [id])
  sentPayments    Payment[]       @relation("SenderWallet")
  receivedPayments Payment[]      @relation("ReceiverWallet")
}

model Invoice {
  id              String          @id @default(cuid())
  smeId           String
  investorId      String?

  title           String
  description     String?
  buyerName       String
  buyerEmail      String
  amountUSDC      BigInt
  dueDate         DateTime
  invoiceNumber   String

  riskScore       Int?
  riskLabel       RiskLabel?
  riskSummary     String?
  advanceRate     Int?

  // Buyer countersignature (anti-fraud): invoice is not listable until signed.
  buyerSignature          String?
  buyerSignedAt           DateTime?
  buyerVerificationToken  String?   @unique

  status          InvoiceStatus   @default(PENDING)
  escrowWalletId  String?
  fundedAt        DateTime?
  settledAt       DateTime?

  feeRate         Int             @default(200)
  feeAmountUSDC   BigInt?

  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  sme             User            @relation("SMEInvoices", fields: [smeId], references: [id])
  investor        User?           @relation("InvestorInvoices", fields: [investorId], references: [id])
  payments        Payment[]
}

enum InvoiceStatus {
  PENDING
  SCORED
  FUNDED
  ACTIVE
  REPAID
  SETTLED
  DEFAULTED
  CANCELLED
}

enum RiskLabel {
  LOW
  MEDIUM
  HIGH
}

model Payment {
  id                  String        @id @default(cuid())
  circlePaymentId     String?       @unique

  senderWalletId      String
  receiverWalletId    String
  invoiceId           String?

  amountUSDC          BigInt
  type                PaymentType
  status              PaymentStatus @default(PENDING)

  txHash              String?
  blockchain          String        @default("ARC")

  metadata            Json?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  senderWallet        Wallet        @relation("SenderWallet", fields: [senderWalletId], references: [id])
  receiverWallet      Wallet        @relation("ReceiverWallet", fields: [receiverWalletId], references: [id])
  invoice             Invoice?      @relation(fields: [invoiceId], references: [id])
}

enum PaymentType {
  ADVANCE
  REPAYMENT
  SETTLEMENT
  FEE
  CROSS_CHAIN
}

enum PaymentStatus {
  PENDING
  CONFIRMED
  FAILED
}

model CreditEvent {
  id          String    @id @default(cuid())
  userId      String
  type        String
  invoiceId   String?
  scoreChange Int
  newScore    Int
  createdAt   DateTime  @default(now())
}

// An investor's idle USDC parked into USYC to earn T-bill yield. Non-custodial:
// the position is held in the investor's own wallet. SIMULATED positions accrue
// yield arithmetically (apyBps × elapsed) on Arc; REAL positions hold actual
// USYC shares from the Sepolia Teller contract.
model YieldPosition {
  id              String        @id @default(cuid())
  userId          String
  principalUSDC   BigInt        // USDC subscribed, in base units (6 decimals)
  shares          String?       // USYC shares received (real mode); null if simulated
  apyBps          Int           // APY snapshot in basis points, for simulated accrual
  mode            YieldMode
  chain           String        // "ARC-TESTNET" (simulated) | "ETH-SEPOLIA" (real)
  status          YieldStatus   @default(ACTIVE)
  subscribeTxHash String?
  redeemTxHash    String?
  openedAt        DateTime      @default(now())
  closedAt        DateTime?

  user            User          @relation(fields: [userId], references: [id])

  @@index([userId, status])
}

enum YieldMode {
  SIMULATED
  REAL
}

enum YieldStatus {
  ACTIVE
  REDEEMED
}
